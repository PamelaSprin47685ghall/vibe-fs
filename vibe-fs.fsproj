    <Compile Include="src/MuxPlugin/MuxWrappers.fs" />
    <Compile Include="src/MuxPlugin/MuxEventHook.fs" />
    <Compile Include="src/MuxPlugin/MuxSlashCommands.fs" />
    <Compile Include="src/MuxPlugin/Registration.fs" />
    <!-- Public JS/TS entry module exposed to mux -->
    <Compile Include="src/Index.fs" />
    <!-- Public API + tests -->
    <Compile Include="src/VibeFs.fs" />
    <Compile Include="tests/Assert.fs" />
    <Compile Include="tests/ReviewTests.fs" />
    <Compile Include="tests/AgentTests.fs" />
    <Compile Include="tests/KernelTests.fs" />
    <Compile Include="tests/FuzzyTests.fs" />
    <Compile Include="tests/ShellTests.fs" />
    <Compile Include="tests/DynTests.fs" />
    <Compile Include="tests/DelegateTests.fs" />
    <Compile Include="tests/ResolveAiSettingsTests.fs" />
    <Compile Include="tests/Tests.fs" />
  </ItemGroup>

</Project>
