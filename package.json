{
  "name": "wanxiangshu",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "description": "wanxiangshu: multi-agent plugin runtime in F#→JS via Fable",
  "main": "build/src/Mux/Plugin.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./build/src/Mux/Plugin.js",
      "require": "./build/src/Mux/Plugin.js",
      "default": "./build/src/Mux/Plugin.js"
    },
    "./omp": {
      "types": "./index.d.ts",
      "import": "./build/src/Omp/Plugin.js",
      "require": "./build/src/Omp/Plugin.js",
      "default": "./build/src/Omp/Plugin.js"
    }
  },
  "files": [
    "build",
    "index.d.ts"
  ],
  "scripts": {
    "build": "dotnet fable wanxiangshu.fsproj --outDir build --noCache",
    "postbuild": "node scripts/postbuild.mjs",
    "test": "node tests/runner.js",
    "build-and-test": "npm run build && npm run test",
    "e2e": "npm run build && node build/tests/runner.js --e2e",
    "e2e:mux": "npm run build && node build/tests/runner.js --e2e-mux",
    "e2e:opencode-plugin": "npm run build && node build/tests/runner.js --e2e-opencode-plugin",
    "e2e-omp": "npm run build && node build/tests/runner.js --e2e-omp"
  },
  "dependencies": {
    "@fable-org/fable-library-js": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@opencode-ai/plugin": "^1.17.4",
    "opencode-pty": "^0.3.4",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "bun-pty": "0.4.8"
  },
  "devDependencies": {
    "eventsource": "^3.0.7"
  },
  "optionalDependencies": {
    "@ff-labs/fff-node": "^0.9.4",
    "@kreuzberg/tree-sitter-language-pack": "^1.8.1",
    "es-module-lexer": "^2.1.0",
    "highlight.js": "^11.11.1",
    "tsx": "^4.22.4"
  }
}
