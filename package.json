{
  "name": "vibe-fs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "vibe-me reimagined in F# compiled to JavaScript via Fable",
  "main": "build/src/Index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./build/src/Index.js",
      "require": "./build/src/Index.js",
      "default": "./build/src/Index.js"
    }
  },
  "files": [
    "build",
    "index.d.ts"
  ],
  "scripts": {
    "clean": "rm -rf build",
    "build": "dotnet fable vibe-fs.fsproj --outDir build --noCache && rm -f build/fable_modules/.gitignore && cp build-package.json build/package.json && cp build/src/Index.js build/index.js",
    "watch": "dotnet fable watch vibe-fs.fsproj --outDir build",
    "test": "node build/tests/Tests.js && node tests/integration.mjs"
  },
  "dependencies": {
    "@fable-org/fable-library-js": "^2.1.1",
    "@opencode-ai/plugin": "^1.17.4"
  },
  "optionalDependencies": {
    "@ff-labs/fff-node": "^0.9.4",
    "@kreuzberg/tree-sitter-language-pack": "^1.8.1",
    "es-module-lexer": "^2.1.0",
    "highlight.js": "^11.11.1",
    "tsx": "^4.22.4"
  }
}
