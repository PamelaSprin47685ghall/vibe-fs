{
  "name": "wanxiangshu",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "description": "wanxiangshu: multi-agent plugin runtime in F#→JS via Fable",
  "main": "build/src/Hosts/Mux/Plugin.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./build/src/Hosts/Mux/Plugin.js",
      "require": "./build/src/Hosts/Mux/Plugin.js",
      "default": "./build/src/Hosts/Mux/Plugin.js"
    },
    "./omp": {
      "types": "./index.d.ts",
      "import": "./build/src/Hosts/Omp/Plugin.js",
      "require": "./build/src/Hosts/Omp/Plugin.js",
      "default": "./build/src/Hosts/Omp/Plugin.js"
    },
    "./wanxiangzhen": {
      "types": "./index.d.ts",
      "import": "./build/src/Hosts/OpenCode/PluginWanxiangzhen.js",
      "require": "./build/src/Hosts/OpenCode/PluginWanxiangzhen.js",
      "default": "./build/src/Hosts/OpenCode/PluginWanxiangzhen.js"
    }
  },
  "files": [
    "build",
    "index.d.ts"
  ],
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.mjs",
    "build": "dotnet fable wanxiangshu.fsproj --outDir build && node scripts/postbuild.mjs",
    "postbuild": "node scripts/postbuild.mjs",
    "test": "node tests/runner.js",
    "test:unit": "node tests/runner.js L0",
    "test:contract": "node tests/runner.js L0 codec",
    "test:integration": "node tests/runner.js L2",
    "test:e2e:p0": "node tests/e2e.js opencode-e2e-p0",
    "test:e2e:full": "node tests/e2e.js opencode-e2e-full",
    "test:e2e:opencode:p0": "node tests/e2e.js opencode-e2e-p0",
    "test:e2e:opencode:full": "node tests/e2e.js opencode-e2e-full",
    "test:gates": "node tests/runner.js L4",
    "test:all": "npm run test:unit && npm run test:contract && npm run test:integration && npm run test:gates && npm run test:e2e:p0 && npm run test:e2e:full",
    "test:release": "npm run build && npm run test:all",
    "validate:coverage": "node --import tsx e2e/opencode/scripts/validate-manifest.mjs",
    "test:stability-gate": "node --import tsx e2e/opencode/scripts/stability-gate.mjs",
    "test:stability-gate:static": "node --import tsx e2e/opencode/scripts/stability-gate.mjs --static-only",
    "build-and-test": "node scripts/build-and-test.mjs",
    "build-and-test-e2e": "node scripts/build-and-test-e2e.mjs",
    "format": "node scripts/pre-commit-formatter.mjs"
  },
  "dependencies": {
    "@fable-org/fable-library-js": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@opencode-ai/plugin": "^1.17.4",
    "opencode-pty": "^0.3.4",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "bun-pty": "0.4.8"
  },
  "devDependencies": {
    "eventsource": "^3.0.7"
  },
  "optionalDependencies": {
    "@ff-labs/fff-node": "^0.9.4",
    "@kreuzberg/tree-sitter-language-pack": "^1.8.1",
    "es-module-lexer": "^2.1.0",
    "highlight.js": "^11.11.1",
    "tsx": "^4.22.4"
  }
}
